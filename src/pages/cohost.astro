---
import Layout from "../layouts/partials/Layout.astro";
import Container from "../layouts/partials/Container.astro";
import Heading2 from "../layouts/components/Heading2.astro";
import HeadingMini from "../layouts/components/HeadingMini.astro";

const cohosts = [
  {
    name: "Universitas Trilogi",
    logo: "https://via.placeholder.com/200x120",
    website: "https://trilogi.ac.id"
  },
  {
    name: "Partner University A",
    logo: "https://via.placeholder.com/200x120",
    website: "#"
  },
  {
    name: "Research Institute B",
    logo: "https://via.placeholder.com/200x120",
    website: "#"
  },
  {
    name: "International Partner C",
    logo: "https://via.placeholder.com/200x120",
    website: "#"
  }
];
---

<Layout title="Co-Host">

  <Container>
    <Heading2 text="Co-Host Institutions" />

    <!-- GRID -->
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6 justify-items-center my-8">

      {
        cohosts.map(item => (
          <a href={item.website} target="_blank"
             class="group w-[200px] bg-white p-4 rounded-xl shadow hover:shadow-lg transition duration-300 text-center">

            <!-- LOGO -->
            <div class="h-[100px] flex items-center justify-center mb-3">
              <img class="max-h-full object-contain group-hover:scale-110 transition duration-300"
                   src={item.logo} />
            </div>

            <!-- NAME -->
            <p class="text-sm font-medium text-gray-700 group-hover:text-blue-600">
              {item.name}
            </p>

          </a>
        ))
      }

    </div>

    <HeadingMini text="More partners coming soon" />

  </Container>

</Layout>