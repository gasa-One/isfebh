---
import Jumbotron from "../layouts/partials/Jumbotron.astro";
import Paragraph from "../layouts/components/Paragraph.astro";
import Layout from "../layouts/partials/Layout.astro";
import Container from "../layouts/partials/Container.astro";
import Contact from "../layouts/components/ContactSub.astro";
import ContactContainer from "../layouts/components/ContactContainer.astro";
import Heading2 from "../layouts/components/Heading2.astro";
import Heading3 from "../layouts/components/Heading3.astro";
import DateSeminar from "../layouts/components/DateSeminar.astro";
import PriceSeminar from "../layouts/components/PriceSeminar.astro";
import Button from "../layouts/helpers/Button.astro";
import ButtonContainer from "../layouts/helpers/ButtonContainer.astro";

const openingSpeakers = [
  {
    name: "Prof. Dr. Example Opening",
    position: "Rector, Trilogi University",
    image: "https://via.placeholder.com/200"
  }
];

const keynoteSpeakers = [
  {
    name: "Dr. Keynote Speaker",
    position: "International Expert",
    image: "https://via.placeholder.com/200"
  }
];

const speakersDay1 = [
  {
    name: "Speaker 1",
    position: "Accounting Expert",
    image: "https://via.placeholder.com/200"
  }
];

const speakersDay2 = [
  {
    name: "Speaker 2",
    position: "Finance Specialist",
    image: "https://via.placeholder.com/200"
  }
];
---

<Layout title="Conference">

  <!-- JUMBOTRON -->
  <Jumbotron src="/jumbotron/seminar-3.webp" />

  <!-- DESCRIPTION -->
  <Container>
    <Paragraph
      text="This conference gathers academics and professionals to bridge theory and practice in accounting, finance, and business."
    />
  </Container>

  <!-- OPENING -->
  <Container>
    <Heading2 text="Opening Speeches" />
    {
      openingSpeakers.map((s) => (
        <div class="flex flex-col lg:flex-row items-center gap-6 my-4 w-3/4 mx-auto">
          <img class="w-40 rounded-lg shadow" src={s.image} />
          <div>
            <h2 class="text-xl font-bold">{s.name}</h2>
            <p class="text-gray-500">{s.position}</p>
          </div>
        </div>
      ))
    }
  </Container>

  <!-- KEYNOTE -->
  <Container>
    <Heading2 text="Keynote Speeches" />
    {
      keynoteSpeakers.map((s) => (
        <div class="flex flex-col lg:flex-row items-center gap-6 my-4 w-3/4 mx-auto">
          <img class="w-40 rounded-lg shadow" src={s.image} />
          <div>
            <h2 class="text-xl font-bold">{s.name}</h2>
            <p class="text-gray-500">{s.position}</p>
          </div>
        </div>
      ))
    }
  </Container>

  <!-- SPEAKER -->
  <Container>
    <Heading2 text="Speaker" />

    <Heading3 text="Day 1" />
    {
      speakersDay1.map((s) => (
        <div class="flex flex-col lg:flex-row items-center gap-6 my-4 w-3/4 mx-auto">
          <img class="w-40 rounded-lg shadow" src={s.image} />
          <div>
            <h2 class="text-xl font-bold">{s.name}</h2>
            <p class="text-gray-500">{s.position}</p>
          </div>
        </div>
      ))
    }

    <Heading3 text="Day 2" />
    {
      speakersDay2.map((s) => (
        <div class="flex flex-col lg:flex-row items-center gap-6 my-4 w-3/4 mx-auto">
          <img class="w-40 rounded-lg shadow" src={s.image} />
          <div>
            <h2 class="text-xl font-bold">{s.name}</h2>
            <p class="text-gray-500">{s.position}</p>
          </div>
        </div>
      ))
    }
  </Container>

  <!-- TIMELINE -->
  <Container>
    <Heading2 text="Timeline" />
    <DateSeminar />
  </Container>

  <!-- PRICE -->
  <Container>
    <Heading2 text="Price" />
    <PriceSeminar />
  </Container>

  <!-- REGISTRATION -->
  <Container>
    <Heading2 text="Registration" />
    <ButtonContainer>
      <Button
        href="#"
        class="fa-solid fa-user-plus"
        title="Conference Registration"
        description="Click this button to register."
      />
    </ButtonContainer>
  </Container>

  <!-- CONTACT -->
  <Container>
    <Heading2 text="Contact Us" />
    <ContactContainer>
      <Contact
        media="WhatsApp"
        class="fa-brands fa-whatsapp"
        text="+62 xxx"
        href="#"
      />
      <Contact
        media="Email"
        class="fa-regular fa-envelope"
        text="email@example.com"
        href="#"
      />
    </ContactContainer>
  </Container>

</Layout>