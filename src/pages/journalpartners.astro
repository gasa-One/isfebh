---
import Layout from "../layouts/partials/Layout.astro";
import Container from "../layouts/partials/Container.astro";
import Heading2 from "../layouts/components/Heading2.astro";
import HeadingMini from "../layouts/components/HeadingMini.astro";

const journals = [
  {
    nama: "International Journal of Accounting",
    logo: "https://via.placeholder.com/200x120",
    website: "https://example.com",
    afiliasi: "Universitas Trilogi",
    index: "Scopus",
    tier: "Q2",
    scope: "Accounting, Finance, Business"
  },
  {
    nama: "Journal of Information Systems",
    logo: "https://via.placeholder.com/200x120",
    website: "https://example.com",
    afiliasi: "Indonesia",
    index: "Sinta",
    tier: "S2",
    scope: "Information Systems, Technology"
  },
  {
    nama: "International Business Review",
    logo: "https://via.placeholder.com/200x120",
    website: "https://example.com",
    afiliasi: "Global University",
    index: "Scopus",
    tier: "Q1",
    scope: "Management, Business Strategy"
  },
  {
    nama: "Journal of Economics",
    logo: "https://via.placeholder.com/200x120",
    website: "https://example.com",
    afiliasi: "ASEAN",
    index: "Sinta",
    tier: "S3",
    scope: "Economics, Development"
  }
];
---

<Layout title="Journal Partners">
  <Container>
    <Heading2 text="Journal Partners" />

    <!-- GRID -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 justify-items-center my-6">

      {
        journals.map(item => (
          <div class="group w-[280px] bg-white rounded-2xl shadow-md hover:shadow-xl transition duration-300 overflow-hidden border">

            <!-- LOGO -->
            <div class="h-[160px] flex items-center justify-center bg-gray-50 p-4">
              <img class="max-h-full object-contain group-hover:scale-110 transition duration-300"
                   src={item.logo} />
            </div>

            <!-- CONTENT -->
            <div class="p-4 text-center space-y-2">

              <!-- TITLE -->
              <a href={item.website} target="_blank">
                <h5 class="font-bold text-lg hover:text-blue-600 transition">
                  {item.nama}
                </h5>
              </a>

              <!-- AFILIASI -->
              <p class="text-sm text-gray-500">
                {item.afiliasi}
              </p>

              <!-- BADGE -->
              <div class="flex justify-center gap-2 flex-wrap mt-2">

                <span class="px-2 py-1 text-xs rounded-full bg-green-100 text-green-700 font-medium">
                  {item.index}
                </span>

                <span class="px-2 py-1 text-xs rounded-full bg-blue-100 text-blue-700 font-medium">
                  {item.tier}
                </span>

              </div>

              <!-- SCOPE -->
              <p class="text-xs text-gray-600 mt-2 line-clamp-2">
                {item.scope}
              </p>

            </div>
          </div>
        ))
      }

    </div>

    <HeadingMini text="more to be announce" />

  </Container>
</Layout>